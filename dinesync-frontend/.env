# DineSync Frontend Environment Variables
# Copy this file to .env and adjust values for your environment.
# Never commit .env to version control (it's already in .gitignore).

REACT_APP_API_BASE_URL=http://localhost:5002

# Sent as X-Kitchen-Secret header on kitchen status update requests
# Must match kitchen.secret in application.properties
REACT_APP_KITCHEN_SECRET=dinesync-kitchen-secret-2024
